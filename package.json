{
  "name": "teams-agent-core",
  "version": "0.0.0",
  "private": true,
  "description": "Meeting transcription, summaries and insights for Microsoft Teams, self-hosted on AWS.",
  "workspaces": [
    "packages/*",
    "extension",
    "backend",
    "infra",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
