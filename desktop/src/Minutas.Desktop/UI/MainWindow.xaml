<Window x:Class="Minutas.Desktop.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Minutix Desktop"
        Icon="/Assets/minutix-mark.png"
        Width="398"
        Height="680"
        MinWidth="378"
        MaxWidth="460"
        MinHeight="620"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="#08090D"
        Foreground="#FAFAFF"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#08090D" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#0E0F16" />
        <SolidColorBrush x:Key="PanelBrush" Color="#11121A" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2C39" />
        <SolidColorBrush x:Key="TextBrush" Color="#FAFAFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#B7B1D8" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#88829E" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#635BFF" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#756EFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#292780" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="OkBrush" Color="#10D897" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A1B26" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#14151E" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#0A0B10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="PasswordInputBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#0A0B10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#171824" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MaxWidth" Value="300" />
        </Style>

        <Style x:Key="SwitchCheckBox" TargetType="CheckBox">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track"
                                Width="48"
                                Height="28"
                                CornerRadius="14"
                                Background="#242532"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Margin="4"
                                     HorizontalAlignment="Left"
                                     Fill="#FAFAFF" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#101119" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Row"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#222331"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#171827" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#27235F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,6,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Image Source="/Assets/minutix-logo-cropped.png"
                       Width="148"
                       Height="49"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       Margin="-5,-7,0,-7" />
                <TextBlock Text="Teams Desktop companion" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
            </StackPanel>
            <Ellipse x:Name="HeaderStatusDot"
                     Grid.Column="1"
                     Width="8"
                     Height="8"
                     Fill="{StaticResource SubtleBrush}"
                     VerticalAlignment="Top"
                     Margin="0,8,4,0" />
        </Grid>

        <Grid x:Name="LoginPanel" Grid.Row="1" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBox x:Name="EmailBox"
                         Style="{StaticResource InputBox}" />
                <TextBlock x:Name="EmailPlaceholder"
                           Text="Email"
                           Foreground="{StaticResource SubtleBrush}"
                           Margin="13,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False" />
            </Grid>
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource PasswordInputBox}" />
                <TextBlock x:Name="PasswordPlaceholder"
                           Text="Contraseña"
                           Foreground="{StaticResource SubtleBrush}"
                           Margin="13,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False" />
            </Grid>
            <Button x:Name="SignInButton"
                    Grid.Row="2"
                    Style="{StaticResource PrimaryButton}"
                    Content="Entrar" />
        </Grid>

        <Grid x:Name="AccountPanel" Grid.Row="1" Margin="0,0,0,14" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="38" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="30"
                    Height="30"
                    CornerRadius="4"
                    Background="{StaticResource AccentBrush}"
                    VerticalAlignment="Center">
                <TextBlock x:Name="AvatarText"
                           Text="M"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#D8D3FF"
                           FontWeight="Bold" />
            </Border>
            <TextBlock x:Name="AccountEmailText"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       FontSize="14" />
            <Button x:Name="SignOutButton"
                    Grid.Column="2"
                    Style="{StaticResource LinkButton}"
                    Content="Salir" />
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Text="Captura automática (subtítulos de Teams)"
                               FontWeight="Bold"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Margin="0" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,14,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="22"
                            Height="22"
                            CornerRadius="11"
                            Background="#1B1C28"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            VerticalAlignment="Top"
                            Margin="0,1,8,0"
                            ToolTip="Crea una reunión en Minutix, lee los subtítulos de Teams Desktop por accesibilidad de Windows y envía segmentos en vivo. No graba audio.">
                        <TextBlock Text="?"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="Lee subtítulos en vivo de Teams Desktop, incluso minimizado. No graba audio."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12.5"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Captura automática al entrar a una reunión"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="AutoCaptureHintText"
                                   Text="Detecta una llamada de Teams Desktop y empieza a transcribir."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,3,12,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox x:Name="AutoCaptureMeetingsCheckBox"
                              Grid.Column="1"
                              Style="{StaticResource SwitchCheckBox}"
                              VerticalAlignment="Center"
                              ToolTip="Cuando está activo, Minutix mira si aparece una reunión de Teams Desktop y arranca la captura de subtítulos automáticamente." />
                </Grid>

                <Button x:Name="StartButton"
                        Grid.Row="3"
                        Style="{StaticResource PrimaryButton}"
                        Content="● Empezar a transcribir"
                        ToolTip="Inicia la captura de subtítulos visibles en Teams Desktop." />

                <Grid x:Name="CapturingPanel" Grid.Row="3" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource DangerBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="Transcribiendo" FontWeight="SemiBold" />
                            <TextBlock Text=" · " Foreground="{StaticResource MutedBrush}" />
                            <TextBlock x:Name="ElapsedText" Text="00:00" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                        <Button x:Name="OpenLiveButton"
                                Grid.Column="1"
                                Style="{StaticResource LinkButton}"
                                Content="Ver en vivo"
                                ToolTip="Abre el panel web de esta reunión." />
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StopButton"
                                Style="{StaticResource PrimaryButton}"
                                Height="38"
                                Content="Detener y resumir"
                                ToolTip="Finaliza la captura y pide el resumen al backend." />
                        <Button x:Name="CancelButton"
                                Grid.Column="2"
                                Style="{StaticResource QuietButton}"
                                Content="Descartar"
                                ToolTip="Detiene esta captura sin finalizar la reunión." />
                    </Grid>
                </Grid>

                <TextBlock x:Name="ModeText"
                           Grid.Row="4"
                           Text="Modo: Subtítulos de Teams Desktop"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           Margin="0,14,0,0" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Iniciar Minutix con Windows"
                               FontWeight="SemiBold"
                               FontSize="13" />
                    <TextBlock x:Name="StartupHintText"
                               Text="Se abre minimizado en la bandeja."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               Margin="0,3,0,0" />
                </StackPanel>
                <CheckBox x:Name="StartupWithWindowsCheckBox"
                          Grid.Column="1"
                          Style="{StaticResource SwitchCheckBox}"
                          VerticalAlignment="Center"
                          ToolTip="Activa o desactiva el inicio automático de Minutix para tu usuario de Windows." />
            </Grid>
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Text="Listo."
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="12"
                   Margin="0,0,0,8" />

        <TextBlock x:Name="ActivityTitle"
                   Grid.Row="5"
                   Text="Últimas reuniones"
                   FontWeight="Bold"
                   Foreground="#CBC6FF"
                   Margin="0,0,0,8" />

        <ListBox x:Name="ActivityList"
                 Grid.Row="6"
                 MouseDoubleClick="ActivityList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Height="36" Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Meta}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button x:Name="OpenPanelButton"
                Grid.Row="7"
                Content="Abrir panel →"
                Style="{StaticResource LinkButton}"
                HorizontalAlignment="Right"
                Margin="0,18,4,4" />
    </Grid>
</Window>
